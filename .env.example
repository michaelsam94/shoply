SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token
# Optional — Partner Dashboard → App → Settings (only for Admin API OAuth client_credentials)
SHOPIFY_CLIENT_ID=your_partner_app_client_id
SHOPIFY_CLIENT_SECRET=your_partner_app_client_secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
# After email confirm / password reset, browser opens this URL. Must be in Supabase
# Authentication → URL Configuration → Redirect URLs. Example (web):
# SUPABASE_EMAIL_REDIRECT=https://your-app.vercel.app
# For local Flutter web: http://localhost:PORT (match your flutter run -d chrome port)
# SUPABASE_EMAIL_REDIRECT=
